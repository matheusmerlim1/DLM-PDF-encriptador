PORT=3000

# ─── DLM PDF API (criptografia centralizada v3) ────────────────────────────────
# URL da DLM PDF API. Novos .dlm v3 são cifrados/decifrados por ela.
DRM_API_URL=http://localhost:3001/api/v1

# ─── Chave mestra local (apenas para .dlm v2 legados) ─────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NUNCA commite o .env real. Pode ser omitida se não houver arquivos v2 antigos.
DLM_MASTER_KEY=cole_aqui_64_chars_hex
